# Fail fast if any staged Go file is not gofmt-clean. Pure Go toolchain, no extra deps.
staged_go="$(git diff --cached --name-only --diff-filter=ACM -- '*.go')"
if [ -n "$staged_go" ]; then
  unformatted="$(printf '%s\n' "$staged_go" | xargs gofmt -l)"
  if [ -n "$unformatted" ]; then
    echo "gofmt: the following staged files need formatting (run 'make fmt'):" >&2
    printf '%s\n' "$unformatted" >&2
    exit 1
  fi
fi
