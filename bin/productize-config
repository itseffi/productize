#!/usr/bin/env node
import path from "node:path";
import { ensureStateDir, readJson, stateDir, writeJson } from "./productize-runtime.mjs";

const [command, key, ...rest] = process.argv.slice(2);
const file = path.join(ensureStateDir(), "config.json");
const config = readJson(file, {});

if (!command || command === "list") {
  console.log(JSON.stringify(config, null, 2));
} else if (command === "path") {
  console.log(file);
} else if (command === "get") {
  if (!key) usage();
  const value = config[key];
  if (value !== undefined) console.log(typeof value === "string" ? value : JSON.stringify(value));
} else if (command === "set") {
  if (!key || !rest.length) usage();
  config[key] = parseValue(rest.join(" "));
  writeJson(file, config);
  console.log(`${key}=${JSON.stringify(config[key])}`);
} else if (command === "state-dir") {
  console.log(stateDir());
} else {
  usage();
}

function parseValue(value) {
  if (value === "true") return true;
  if (value === "false") return false;
  if (/^-?\d+(\.\d+)?$/.test(value)) return Number(value);
  return value;
}

function usage() {
  console.error("Usage: productize-config [list|path|state-dir|get KEY|set KEY VALUE]");
  process.exit(2);
}
