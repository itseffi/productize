#!/usr/bin/env node
import { existsSync, mkdirSync, readFileSync, writeFileSync } from "node:fs";
import path from "node:path";

const args = process.argv.slice(2);
const force = args.includes("--force");
const required = (getFlagValue("--mode") || "optional") === "required";
const cwd = process.cwd();

mkdirSync(path.join(cwd, ".productize"), { recursive: true });
writeFileIfAllowed(
  path.join(cwd, ".productize", "team.json"),
  JSON.stringify(
    {
      productize_team_mode: required ? "required" : "optional",
      default_route: "Use the root productize skill for ambiguous product work, then hand off to the narrowest lifecycle skill.",
      evidence_standard: ["known", "assumed", "missing", "risky"],
      artifact_contract: ["route", "context read", "artifact", "next action"],
    },
    null,
    2,
  ),
);

writeFileIfAllowed(
  path.join(cwd, "AGENTS.md"),
  teamInstructions("AGENTS.md", required),
);

writeFileIfAllowed(
  path.join(cwd, "CLAUDE.md"),
  teamInstructions("CLAUDE.md", required),
);

console.log(`Productize team mode initialized as ${required ? "required" : "optional"}.`);

function teamInstructions(fileName, isRequired) {
  return `# Productize Team Workflow

Productize team mode is ${isRequired ? "required" : "optional"} for product work in this repo.

Use the root \`productize\` skill when a product request is ambiguous or spans more
than one lifecycle stage. Route to the narrowest Productize lifecycle skill once
the artifact is clear.

Every durable product artifact should include:

- Route: selected skill or skill sequence.
- Evidence: known facts, assumptions, missing inputs, and risky leaps.
- Artifact: PRD, strategy memo, research plan, positioning, experiment, deck,
  roadmap, AI-builder handoff, or stakeholder narrative.
- Next action: owner, validation step, metric, or decision.

Do not produce generic strategy filler. Tie recommendations to the current product
stage, user persona, business context, and available evidence.

Generated by \`productize-team-init\` for ${fileName}.
`;
}

function writeFileIfAllowed(file, content) {
  if (existsSync(file) && !force) {
    console.log(`Skipped existing ${path.relative(cwd, file)}. Use --force to replace it.`);
    return;
  }
  writeFileSync(file, content.endsWith("\n") ? content : `${content}\n`, "utf8");
  console.log(`Wrote ${path.relative(cwd, file)}`);
}

function getFlagValue(flag) {
  const equals = args.find((arg) => arg.startsWith(`${flag}=`));
  if (equals) return equals.slice(flag.length + 1);
  const index = args.indexOf(flag);
  return index === -1 ? undefined : args[index + 1];
}
