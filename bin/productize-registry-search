#!/usr/bin/env node
import { recordRoutingDecision, route, searchRegistry } from "./productize-runtime.mjs";

const args = process.argv.slice(2);
const json = args.includes("--json");
const query = args.filter((arg) => arg !== "--json").join(" ");
if (!query) {
  console.error("Usage: productize-registry-search [--json] <query>");
  process.exit(2);
}
const results = searchRegistry(query, Number(process.env.PRODUCTIZE_SEARCH_LIMIT || 10));
recordRoutingDecision(query, route(query, Number(process.env.PRODUCTIZE_SEARCH_LIMIT || 10)), "registry-search");
if (json) {
  console.log(JSON.stringify(results, null, 2));
} else {
  for (const result of results) {
    console.log(`${result.name}\t${result.lifecycle}\t${result.title}`);
  }
}
