#!/usr/bin/env node
import path from "node:path";
import { appendJsonl, ensureStateDir } from "./productize-runtime.mjs";

const message = process.argv.slice(2).join(" ");
if (!message) {
  console.error("Usage: productize-session-log <decision or workflow note>");
  process.exit(2);
}
const file = path.join(ensureStateDir(), "session-log.jsonl");
appendJsonl(file, { message });
console.log(file);
