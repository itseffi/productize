#!/usr/bin/env node
import { existsSync, readFileSync } from "node:fs";
import { spawnSync } from "node:child_process";
import path from "node:path";
import { productizeRoot, productizeVersion } from "./productize-runtime.mjs";

const args = process.argv.slice(2);
const checkOnly = args.includes("--check");
const host = valueFor("--host") || "all";
const force = args.includes("--force");

if (!["auto", "codex", "claude", "cursor", "opencode", "factory", "all"].includes(host)) {
  fail(`Unknown --host value: ${host}`);
}

const packageJson = JSON.parse(readFileSync(path.join(productizeRoot, "package.json"), "utf8"));
if (packageJson.version !== productizeVersion()) {
  fail(`VERSION (${productizeVersion()}) does not match package.json (${packageJson.version}).`);
}

for (const file of ["CHANGELOG.md", "RELEASE.md", "UPGRADE.md", "setup"]) {
  if (!existsSync(path.join(productizeRoot, file))) fail(`Missing upgrade/release file: ${file}`);
}

if (checkOnly) {
  console.log(`Productize ${productizeVersion()} upgrade metadata is present.`);
  process.exit(0);
}

const setupArgs = ["./setup", "--host", host];
if (force) setupArgs.push("--force");
const result = spawnSync(setupArgs[0], setupArgs.slice(1), {
  cwd: productizeRoot,
  stdio: "inherit",
});
process.exit(result.status || 0);

function valueFor(flag) {
  const equals = args.find((arg) => arg.startsWith(`${flag}=`));
  if (equals) return equals.slice(flag.length + 1);
  const index = args.indexOf(flag);
  return index === -1 ? undefined : args[index + 1];
}

function fail(message) {
  console.error(message);
  process.exit(1);
}
