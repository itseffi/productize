#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import { existsSync } from "node:fs";
import path from "node:path";
import { updateStatus, productizeRoot } from "./productize-runtime.mjs";

const strict = process.argv.includes("--strict");
const status = updateStatus();

if (strict) {
  const validator = path.join(productizeRoot, "scripts", "validate-skills.mjs");
  if (!existsSync(validator)) {
    status.validation_status = "unavailable";
    status.validation_output = "Full validator is not installed with runtime sidecars.";
    console.log(JSON.stringify(status, null, 2));
    process.exit(0);
  }
  const result = spawnSync(process.execPath, ["scripts/validate-skills.mjs"], {
    cwd: productizeRoot,
    encoding: "utf8",
  });
  status.validation_status = result.status === 0 ? "fresh" : "stale";
  status.validation_output = `${result.stdout || ""}${result.stderr || ""}`.trim();
  if (result.status !== 0) {
    console.log(JSON.stringify(status, null, 2));
    process.exit(result.status || 1);
  }
}

console.log(JSON.stringify(status, null, 2));
