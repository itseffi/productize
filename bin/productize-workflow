#!/usr/bin/env node
import {
  completeWorkflow,
  latestWorkflow,
  readJson,
  startWorkflow,
  workflowPath,
} from "./productize-runtime.mjs";

const args = process.argv.slice(2);
const command = args.shift();

try {
  if (command === "start") {
    const json = takeBoolean("--json");
    const request = remainingText();
    const workflow = startWorkflow(request);
    if (json) printJson(workflow);
    else printStart(workflow);
  } else if (command === "complete") {
    const json = takeBoolean("--json");
    const workflow = completeWorkflow({
      id: takeValue("--id"),
      status: takeValue("--status"),
      artifactType: takeValue("--artifact-type"),
      summary: takeValue("--summary"),
      contextSummary: takeValue("--context-summary"),
    });
    if (json) printJson(workflow);
    else printComplete(workflow);
  } else if (command === "status") {
    const json = takeBoolean("--json");
    const id = takeValue("--id");
    const workflow = id ? readJson(workflowPath(id), null) : latestWorkflow();
    if (!workflow) throw new Error("No Productize workflow found.");
    if (json) printJson(workflow);
    else printStart(workflow);
  } else {
    usage();
  }
} catch (error) {
  console.error(error.message);
  process.exit(1);
}

function printStart(workflow) {
  console.log(`Workflow: ${workflow.id}`);
  console.log(`Status: ${workflow.status}`);
  console.log(`Persona: ${workflow.classification.persona}`);
  console.log(`Stage: ${workflow.classification.product_stage}`);
  console.log(`Artifact mode: ${workflow.classification.artifact_mode}`);
  console.log(`Decision mode: ${workflow.classification.decision_mode}`);
  if (workflow.routes[0]) {
    const route = workflow.routes[0];
    console.log(`Route: ${route.name} (${route.lifecycle} / ${route.category})`);
    console.log(`Expected artifact: ${route.output_artifact}`);
  }
  if (workflow.restored_context) {
    console.log(`Restored context: ${workflow.restored_context.summary}`);
  }
  console.log(`Complete with: ${workflow.required_completion.command.replace("<id>", workflow.id)}`);
}

function printComplete(workflow) {
  console.log(`Workflow: ${workflow.id}`);
  console.log(`Status: ${workflow.status}`);
  console.log(`Artifact type: ${workflow.artifact_type}`);
  console.log(`Summary: ${workflow.summary}`);
  if (workflow.saved_context) console.log(`Saved context: ${workflow.saved_context}`);
}

function printJson(value) {
  console.log(JSON.stringify(value, null, 2));
}

function takeBoolean(flag) {
  const index = args.indexOf(flag);
  if (index === -1) return false;
  args.splice(index, 1);
  return true;
}

function takeValue(flag) {
  const equalsIndex = args.findIndex((arg) => arg.startsWith(`${flag}=`));
  if (equalsIndex !== -1) {
    const [value] = args.splice(equalsIndex, 1);
    return value.slice(flag.length + 1);
  }
  const index = args.indexOf(flag);
  if (index === -1) return undefined;
  const value = args[index + 1];
  args.splice(index, 2);
  return value;
}

function remainingText() {
  return args.join(" ").trim();
}

function usage() {
  console.error(`Usage:
  productize-workflow start [--json] <user-request>
  productize-workflow complete --id ID --status completed|blocked|deferred|needs-review --artifact-type TYPE --summary SUMMARY [--context-summary SUMMARY] [--json]
  productize-workflow status [--json]`);
  process.exit(2);
}
