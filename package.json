{
  "name": "@productize/agent-skills",
  "version": "1.1.2",
  "description": "Productize skills and runtime for building, shipping, operating, and growing AI products inside coding harnesses.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itseffi/productize.git"
  },
  "bugs": {
    "url": "https://github.com/itseffi/productize/issues"
  },
  "homepage": "https://github.com/itseffi/productize#readme",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".agents/",
    ".claude/",
    ".claude-plugin/",
    ".cursor/",
    ".factory/",
    ".opencode/",
    "agents/",
    "assets/",
    "bin/",
    "hosts/",
    "plugins/",
    "registry/",
    "scripts/",
    "skills/",
    "setup",
    "CHANGELOG.md",
    "README.md",
    "RELEASE.md",
    "SKILL.md",
    "SKILL.md.tmpl",
    "UPGRADE.md",
    "VERSION"
  ],
  "bin": {
    "agent-skills": "setup",
    "productize": "setup",
    "productize-setup": "setup",
    "productize-config": "bin/productize-config",
    "productize-update-check": "bin/productize-update-check",
    "productize-skill-router": "bin/productize-skill-router",
    "productize-session-log": "bin/productize-session-log",
    "productize-artifact-log": "bin/productize-artifact-log",
    "productize-context-save": "bin/productize-context-save",
    "productize-context-restore": "bin/productize-context-restore",
    "productize-registry-search": "bin/productize-registry-search",
    "productize-completion-status": "bin/productize-completion-status",
    "productize-workflow": "bin/productize-workflow",
    "productize-upgrade": "bin/productize-upgrade",
    "productize-team-init": "bin/productize-team-init"
  },
  "scripts": {
    "skills:normalize": "node scripts/normalize-skills.mjs",
    "skills:import:pm": "node scripts/import-pm-skills.mjs",
    "skills:generate": "node scripts/gen-skill-docs.mjs --host canonical --quiet",
    "skills:generate:all": "node scripts/gen-skill-docs.mjs --host all --quiet",
    "skills:audit": "node scripts/audit-skills.mjs",
    "skills:index": "node scripts/index-skills.mjs",
    "skills:validate": "node scripts/validate-skills.mjs",
    "skill:check": "node scripts/validate-skills.mjs",
    "repo:hygiene": "node scripts/check-repo-hygiene.mjs",
    "repo:hygiene:local": "node scripts/check-repo-hygiene.mjs --allow-copied-tree",
    "plugins:build:codex": "node scripts/build-plugins.mjs --codex",
    "plugins:build:claude": "node scripts/build-plugins.mjs --claude",
    "plugins:build": "node scripts/build-plugins.mjs",
    "plugins:install:codex": "node scripts/install-codex-plugins.mjs",
    "skills:install:claude": "node scripts/install-claude-skills.mjs",
    "site:index": "node scripts/build-site-index.mjs",
    "test": "npm run test:free",
    "test:unit": "npm run test:parser && npm run test:generator && npm run test:registry && npm run test:routes && npm run test:plugins && npm run test:metadata && npm run test:hygiene && npm run test:setup && npm run test:runtime && npm run test:release && npm run test:eval-runner",
    "test:free": "npm run test:unit && npm run test:finance && npm run test:setup-host",
    "test:parser": "node scripts/test-skill-parser.mjs",
    "test:generator": "node test/generator.test.mjs",
    "test:registry": "node test/registry.test.mjs",
    "test:routes": "node test/route-regression.test.mjs",
    "test:plugins": "node test/plugin-distribution.test.mjs",
    "test:metadata": "node test/metadata-quality.test.mjs",
    "test:hygiene": "node test/repo-hygiene.test.mjs",
    "test:setup": "node test/setup-script.test.mjs",
    "test:runtime": "node test/runtime-workflow.test.mjs",
    "test:setup-host": "node test/setup-host.test.mjs",
    "test:finance": "python3 skills/finance-modeling-kernel/finance-modeling-kernel/tests/test_acceptance.py",
    "test:release": "node test/release.test.mjs",
    "test:eval-runner": "node test/eval-runner.test.mjs",
    "test:e2e": "npm run eval:e2e && npm run install:smoke",
    "test:evals": "npm run eval",
    "test:gate": "npm run test:free && npm run eval:router && npm run eval:e2e",
    "test:periodic": "npm run eval:periodic",
    "eval": "node scripts/eval-productize.mjs",
    "eval:router": "node scripts/eval-productize.mjs --router-only",
    "eval:e2e": "node scripts/eval-productize.mjs --e2e-only",
    "eval:llm": "node scripts/eval-llm-offline.mjs",
    "eval:llm:offline": "node scripts/eval-llm-offline.mjs",
    "eval:periodic": "node scripts/eval-productize.mjs --e2e",
    "eval:report": "node scripts/report-eval-results.mjs .productize-evals",
    "install:smoke": "node scripts/install-smoke-test.mjs",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "release:check": "node scripts/release-check.mjs",
    "upgrade:check": "node bin/productize-upgrade --check",
    "ci": "npm run repo:hygiene && npm run build && npm run test && npm run eval && npm run install:smoke && npm run release:check && npm run upgrade:check",
    "build": "npm run skills:normalize && npm run skills:generate:all && npm run skills:audit && npm run skills:index && npm run plugins:build && npm run site:index && npm run skill:check"
  }
}
